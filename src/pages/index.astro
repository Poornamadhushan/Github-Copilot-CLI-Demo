---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StepCard from "../components/StepCard.astro";
import TerminalPreview from "../components/TerminalPreview.astro";
import CodeBlock from "../components/CodeBlock.astro";

const steps = [
  {
    step: "01",
    title: "Understand GitHub CLI",
    description: "Get a mental model of what gh can do for your day-to-day workflow.",
  },
  {
    step: "02",
    title: "Install and authenticate",
    description: "Set up gh on Windows, macOS, or Linux and sign in once.",
  },
  {
    step: "03",
    title: "Practice core commands",
    description: "Clone, create repos, and manage issues from the terminal.",
  },
  {
    step: "04",
    title: "Build the Weather CLI",
    description: "Create a real Node.js CLI that fetches weather for any city.",
  },
];
---
<BaseLayout
  title="GitHub CLI Weather Lab"
  description="A modern training site for learning GitHub CLI through a Weather CLI demo project."
>
  <div class="relative">
    <Header />

    <section class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10">
        <div class="absolute -top-24 right-0 h-80 w-80 rounded-full bg-sky-200/60 blur-[120px]"></div>
        <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-emerald-200/50 blur-[140px]"></div>
      </div>
      <div class="section-pad">
        <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.1fr_0.9fr]">
          <div class="space-y-6">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[color:var(--accent)]">
              GitHub CLI training
            </p>
            <h1 class="text-4xl font-semibold md:text-5xl">
              Learn GitHub CLI by building a Weather CLI demo.
            </h1>
            <p class="text-lg text-[color:var(--text-muted)]">
              A hands-on learning path that teaches installation, authentication, core gh commands, and a real Node.js CLI that fetches live weather.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/docs/introduction" class="rounded-full bg-[color:var(--accent)] px-6 py-3 text-sm font-semibold text-white shadow-soft">
                Start learning
              </a>
              <a href="/docs/build-weather-cli" class="rounded-full border border-[color:var(--border)] px-6 py-3 text-sm font-semibold">
                Build the Weather CLI
              </a>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--card)] p-4 text-sm">
                <p class="font-semibold">What you will build</p>
                <p class="mt-2 text-[color:var(--text-muted)]">A Node.js CLI that accepts a city name, fetches weather data, and prints the forecast in a clean terminal format.</p>
              </div>
              <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--card)] p-4 text-sm">
                <p class="font-semibold">What you will master</p>
                <p class="mt-2 text-[color:var(--text-muted)]">Install gh, authenticate, clone and create repositories, and inspect issues without leaving the terminal.</p>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <TerminalPreview
              title="Weather CLI demo"
              lines={[
                "$ node index.js Colombo",
                "Weather in Colombo",
                "Condition: Partly cloudy",
                "Temperature: 30 C",
                "Humidity: 70%",
              ]}
            />
            <CodeBlock
              title="Quick start"
              code={`gh auth login\n\nnode index.js Colombo`}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--card)] p-6 shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Feature</p>
          <h3 class="mt-3 text-lg font-semibold">Real command practice</h3>
          <p class="mt-2 text-sm text-[color:var(--text-muted)]">
            Each lesson uses the exact gh commands you will run in your terminal.
          </p>
        </div>
        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--card)] p-6 shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Feature</p>
          <h3 class="mt-3 text-lg font-semibold">Terminal-first design</h3>
          <p class="mt-2 text-sm text-[color:var(--text-muted)]">
            Code blocks look like real terminals and include copy buttons.
          </p>
        </div>
        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--card)] p-6 shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Feature</p>
          <h3 class="mt-3 text-lg font-semibold">Weather CLI walkthrough</h3>
          <p class="mt-2 text-sm text-[color:var(--text-muted)]">
            Build a complete Node.js CLI that fetches real weather data.
          </p>
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="mx-auto max-w-6xl space-y-10">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[color:var(--accent)]">Learning steps</p>
            <h2 class="text-3xl font-semibold">A guided flow from setup to a working CLI.</h2>
          </div>
          <a href="/docs/introduction" class="text-sm font-semibold text-[color:var(--accent)]">Open the guide</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {steps.map((item) => (
            <StepCard {...item} />
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[color:var(--accent)]">Demo preview</p>
          <h2 class="text-3xl font-semibold">See the Weather CLI before you build it.</h2>
          <p class="text-sm text-[color:var(--text-muted)]">
            The demo uses a public weather API, parses JSON, and prints the condition, temperature, and humidity. You will build the same thing step by step.
          </p>
          <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--card)] p-5 text-sm">
            <p class="font-semibold">API used</p>
            <p class="mt-2 text-[color:var(--text-muted)]">https://wttr.in/{"{"}city{"}"}?format=j1</p>
          </div>
        </div>
        <TerminalPreview
          title="Expected output"
          lines={[
            "$ node index.js Tokyo",
            "Weather in Tokyo",
            "Condition: Clear",
            "Temperature: 28 C",
            "Humidity: 62%",
          ]}
        />
      </div>
    </section>

    <section class="section-pad">
      <div class="mx-auto max-w-6xl rounded-3xl border border-[color:var(--border)] bg-[color:var(--card)] p-10 shadow-soft">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[color:var(--accent)]">Ready to start</p>
            <h2 class="text-3xl font-semibold">Launch the GitHub CLI training path now.</h2>
            <p class="mt-2 text-sm text-[color:var(--text-muted)]">Everything you need is in the docs: install steps, commands, and the full Weather CLI walkthrough.</p>
          </div>
          <a href="/docs/introduction" class="rounded-full bg-[color:var(--accent)] px-6 py-3 text-sm font-semibold text-white shadow-soft">
            Start the tutorial
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</BaseLayout>
