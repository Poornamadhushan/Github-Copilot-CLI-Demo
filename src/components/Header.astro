---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/docs/introduction", label: "Docs" },
  { href: "/docs/build-weather-cli", label: "Weather CLI" },
  { href: "/docs/run-weather-cli", label: "Run Demo" },
];
---
<header class="sticky top-0 z-50 border-b border-[color:var(--border)] bg-[color:var(--bg-soft)]/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-12">
    <a href="/" class="flex items-center gap-3 text-lg font-semibold">
      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-[color:var(--accent)] text-white">gh</span>
      <span>GitHub CLI Weather Lab</span>
    </a>
    <nav class="hidden items-center gap-6 text-sm font-medium md:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="transition hover:text-[color:var(--accent)]">
          {link.label}
        </a>
      ))}
    </nav>
    <details class="relative md:hidden">
      <summary class="cursor-pointer rounded-full border border-[color:var(--border)] px-4 py-2 text-sm font-semibold">
        Menu
      </summary>
      <div class="absolute right-0 mt-2 w-48 rounded-2xl border border-[color:var(--border)] bg-[color:var(--card)] p-4 shadow-soft">
        <div class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a href={link.href} class="text-sm font-medium hover:text-[color:var(--accent)]">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </details>
  </div>
</header>
